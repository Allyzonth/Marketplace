# Firebase Firestore Configuration
# Get these from Firebase Console > Project Settings > Service Accounts

# Your Firebase project ID
FIREBASE_PROJECT_ID=your_project_id_here

# Private Key ID from service account JSON
FIREBASE_PRIVATE_KEY_ID=your_private_key_id_here

# Private Key from service account JSON
# IMPORTANT: Replace actual newlines with \n
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_actual_private_key_here\n-----END PRIVATE KEY-----\n"

# Client email from service account JSON
FIREBASE_CLIENT_EMAIL=your_service_account_email@appspot.gserviceaccount.com

# Client ID from service account JSON
FIREBASE_CLIENT_ID=your_client_id_here

# Client X509 certificate URL from service account JSON
FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/your_service_account_email%40appspot.gserviceaccount.com
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com

# Server Configuration
PORT=5000
NODE_ENV=development
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password
ADMIN_JWT_SECRET=your_long_random_jwt_secret
